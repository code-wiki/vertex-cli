#!/bin/bash

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
MAGENTA='\033[0;35m'
CYAN='\033[0;36m'
WHITE='\033[1;37m'
BOLD='\033[1m'
NC='\033[0m' # No Color

CONFIG_FILE="$HOME/.ai-tools-config"

# Clear any cached GCP project on startup
gcloud config unset project 2>/dev/null || true

# Function to check if running on GCP
check_gcp_environment() {
    if curl -s -f -H "Metadata-Flavor: Google" http://metadata.google.internal/computeMetadata/v1/instance/id &> /dev/null; then
        echo -e "${GREEN}✓ Running on GCP VM${NC}"
        return 0
    else
        echo -e "${YELLOW}⚠ Running on local machine${NC}"
        return 1
    fi
}

# Function to check gcloud CLI
check_gcloud() {
    if command -v gcloud &> /dev/null; then
        PROJECT_ID=$(gcloud config get-value project 2>/dev/null)
        if [ -n "$PROJECT_ID" ]; then
            echo -e "${GREEN}✓ gcloud CLI configured (Project: $PROJECT_ID)${NC}"
            return 0
        else
            echo -e "${CYAN}✓ gcloud CLI installed (No project set yet)${NC}"
            return 0
        fi
    else
        echo -e "${RED}✗ gcloud CLI not found${NC}"
        return 1
    fi
}

# Function to check authentication status
check_auth_status() {
    if gcloud auth application-default print-access-token &> /dev/null 2>&1; then
        CURRENT_ACCOUNT=$(gcloud auth list --filter=status:ACTIVE --format="value(account)" 2>/dev/null | head -n1)
        if [ -n "$CURRENT_ACCOUNT" ]; then
            echo -e "${GREEN}✓ Authenticated as: $CURRENT_ACCOUNT${NC}"
            return 0
        fi
    fi
    echo -e "${YELLOW}⚠ Not authenticated${NC}"
    return 1
}

# Function to list and select GCP projects
select_gcp_project() {
    echo -e "${BOLD}${MAGENTA}\n─── Select GCP Project ───${NC}"
    echo ""
    echo -e "${CYAN}Fetching your GCP projects...${NC}"
    echo ""
    
    local projects=$(gcloud projects list --format="value(projectId,name)" 2>/dev/null)
    
    if [ -z "$projects" ]; then
        echo -e "${YELLOW}⚠ No projects found or unable to fetch projects${NC}"
        read -p "$(echo -e "${CYAN}Enter Project ID manually: ${NC}")" PROJECT_ID
        gcloud config set project "$PROJECT_ID"
        return
    fi
    
    local project_array=()
    while IFS= read -r line; do
        project_array+=("$line")
    done <<< "$projects"
    
    echo -e "${BOLD}${WHITE}Available projects:${NC}"
    for i in "${!project_array[@]}"; do
        echo -e "  ${YELLOW}$((i+1)))${NC} ${GREEN}${project_array[$i]}${NC}"
    done
    echo -e "  ${YELLOW}0)${NC} ${CYAN}Enter project ID manually${NC}"
    echo ""
    
    read -p "$(echo -e "${BOLD}${CYAN}Select project (0-${#project_array[@]}): ${NC}")" selection
    
    if [ "$selection" = "0" ]; then
        read -p "$(echo -e "${CYAN}Enter Project ID: ${NC}")" PROJECT_ID
    elif [ "$selection" -ge 1 ] && [ "$selection" -le "${#project_array[@]}" ]; then
        PROJECT_ID=$(echo "${project_array[$((selection-1))]}" | awk '{print $1}')
    else
        echo -e "${RED}✗ Invalid selection${NC}"
        return 1
    fi
    
    gcloud config set project "$PROJECT_ID"
    gcloud auth application-default set-quota-project "$PROJECT_ID" 2>/dev/null || true
    echo -e "${BOLD}${GREEN}✓ Project set to: ${CYAN}$PROJECT_ID${NC}"
}

# Function to enable required APIs
enable_vertex_apis() {
    echo -e "${BOLD}${MAGENTA}\n─── Enable Vertex AI APIs ───${NC}"
    echo ""
    
    local project_id=$(gcloud config get-value project 2>/dev/null)
    if [ -z "$project_id" ]; then
        echo -e "${RED}✗ No project selected${NC}"
        return 1
    fi
    
    echo -e "${CYAN}Enabling APIs for project: ${YELLOW}$project_id${NC}"
    echo ""
    
    local apis=("aiplatform.googleapis.com" "compute.googleapis.com")
    
    for api in "${apis[@]}"; do
        echo -ne "${CYAN}Enabling ${WHITE}$api${CYAN}... ${NC}"
        if gcloud services enable "$api" --project="$project_id" 2>/dev/null; then
            echo -e "${BOLD}${GREEN}✓${NC}"
        else
            echo -e "${YELLOW}(already enabled or failed)${NC}"
        fi
    done
    
    echo ""
    echo -e "${BOLD}${GREEN}✓ API setup complete${NC}"
}

# Function to check Vertex AI permissions
check_vertex_permissions() {
    echo -e "${BLUE}\n--- Check Vertex AI Permissions ---${NC}"
    echo ""
    
    local project_id=$(gcloud config get-value project 2>/dev/null)
    local account=$(gcloud auth list --filter=status:ACTIVE --format="value(account)" 2>/dev/null | head -n1)
    
    echo "Project: $project_id"
    echo "Account: $account"
    echo ""
    
    echo "Checking permissions..."
    
    if gcloud services list --enabled --filter="name:aiplatform.googleapis.com" --project="$project_id" 2>/dev/null | grep -q aiplatform; then
        echo -e "${GREEN}✓ Vertex AI API enabled${NC}"
    else
        echo -e "${RED}✗ Vertex AI API not enabled${NC}"
        read -p "Enable now? (y/n): " enable_api
        if [ "$enable_api" = "y" ]; then
            enable_vertex_apis
        fi
    fi
    
    echo ""
    read -p "Press Enter to continue..."
}

# Function to manage GCP configuration
manage_gcp_config() {
    echo -e "${BLUE}\n--- GCP Configuration Management ---${NC}"
    echo ""
    echo "1) List all projects"
    echo "2) Select/Switch project"
    echo "3) Enable Vertex AI APIs"
    echo "4) Check permissions"
    echo "5) View current GCP config"
    echo "6) Back to main menu"
    echo ""
    read -p "Select option (1-6): " gcp_choice
    
    case $gcp_choice in
        1)
            echo ""
            gcloud projects list
            echo ""
            read -p "Press Enter to continue..."
            ;;
        2)
            select_gcp_project
            ;;
        3)
            enable_vertex_apis
            ;;
        4)
            check_vertex_permissions
            ;;
        5)
            echo ""
            echo -e "${BLUE}Current GCP Configuration:${NC}"
            gcloud config list
            echo ""
            read -p "Press Enter to continue..."
            ;;
        6)
            return 0
            ;;
        *)
            echo -e "${RED}Invalid option${NC}"
            ;;
    esac
}

# Function to authenticate user
authenticate_gcp() {
    clear
    echo -e "${CYAN}╔══════════════════════════════════════════════════════════╗${NC}"
    echo -e "${CYAN}║                                                          ║${NC}"
    echo -e "${CYAN}║              ${BOLD}🔐 GCP AUTHENTICATION${NC}                      ${CYAN}║${NC}"
    echo -e "${CYAN}║                                                          ║${NC}"
    echo -e "${CYAN}╚══════════════════════════════════════════════════════════╝${NC}"
    echo ""
    echo -e "${YELLOW}What will happen:${NC}"
    echo "  • Your browser will open ONCE"
    echo "  • Sign in with your Google account"
    echo "  • Grant permissions to gcloud"
    echo ""
    echo -e "${GREEN}This sets up both gcloud and application credentials.${NC}"
    echo ""
    read -p "$(echo -e "${CYAN}Press Enter to authenticate (Ctrl+C to cancel)...${NC}")"
    echo ""
    
    echo -e "${CYAN}→ Authenticating with Google Cloud...${NC}"
    echo ""
    
    if gcloud auth login --update-adc --brief; then
        # Clear any default project
        gcloud config unset project 2>/dev/null
        
        CURRENT_ACCOUNT=$(gcloud auth list --filter=status:ACTIVE --format="value(account)" 2>/dev/null | head -n1)
        echo ""
        echo -e "${GREEN}╔══════════════════════════════════════════════════════════╗${NC}"
        echo -e "${GREEN}║                                                          ║${NC}"
        echo -e "${GREEN}║              ${BOLD}✓ READY TO USE VERTEX CLI!${NC}                ${GREEN}║${NC}"
        echo -e "${GREEN}║                                                          ║${NC}"
        echo -e "${GREEN}║${NC}  Authenticated as: ${YELLOW}$CURRENT_ACCOUNT${NC}"
        echo -e "${GREEN}║                                                          ║${NC}"
        echo -e "${GREEN}╚══════════════════════════════════════════════════════════╝${NC}"
        echo ""
        echo -e "${CYAN}Next: Configure Claude or Gemini and select your project${NC}"
        echo ""
        read -p "$(echo -e "${YELLOW}Press Enter to continue...${NC}")"
        return 0
    fi
    
    echo ""
    echo -e "${RED}✗ Authentication failed${NC}"
    echo "Check your internet connection and try again."
    echo ""
    read -p "$(echo -e "${YELLOW}Press Enter to continue...${NC}")"
    return 1
}

# Function to switch/re-authenticate GCP account
switch_gcp_account() {
    echo -e "${BLUE}\n--- Switch GCP Account ---${NC}"
    echo ""
    echo "Current authentication status:"
    check_auth_status || true
    echo ""
    echo "Options:"
    echo "1) Re-authenticate with different account"
    echo "2) Revoke all credentials"
    echo "3) List authenticated accounts"
    echo "4) Back to main menu"
    echo ""
    read -p "Select option (1-4): " switch_choice
    
    case $switch_choice in
        1)
            echo ""
            echo -e "${BLUE}Re-authenticating...${NC}"
            authenticate_gcp
            ;;
        2)
            echo ""
            echo -e "${YELLOW}Revoking all credentials...${NC}"
            gcloud auth application-default revoke 2>/dev/null || true
            gcloud auth revoke --all 2>/dev/null || true
            echo -e "${GREEN}✓ All credentials revoked${NC}"
            echo ""
            read -p "Authenticate with new account? (y/n): " auth_new
            if [ "$auth_new" = "y" ]; then
                authenticate_gcp
            fi
            ;;
        3)
            echo ""
            echo -e "${BLUE}Authenticated accounts:${NC}"
            gcloud auth list
            echo ""
            read -p "Press Enter to continue..."
            ;;
        4)
            return 0
            ;;
        *)
            echo -e "${RED}Invalid option${NC}"
            ;;
    esac
}

# Function to save configuration
save_config() {
    local ai_tool=$1
    local config_data=$2
    echo "AI_TOOL=$ai_tool" > "$CONFIG_FILE"
    echo "$config_data" >> "$CONFIG_FILE"
    echo -e "${GREEN}✓ Configuration saved to $CONFIG_FILE${NC}"
}

# Function to load configuration
load_config() {
    if [ -f "$CONFIG_FILE" ]; then
        source "$CONFIG_FILE"
        return 0
    else
        return 1
    fi
}

# Function to configure Claude (Vertex AI)
configure_claude() {
    clear
    # Clear any cached project first
    gcloud config unset project 2>/dev/null || true

    echo -e "${BLUE}╔══════════════════════════════════════════════════════════╗${NC}"
    echo -e "${BLUE}║                                                          ║${NC}"
    echo -e "${BLUE}║           🤖 CONFIGURE CLAUDE (VERTEX AI)              ║${NC}"
    echo -e "${BLUE}║                                                          ║${NC}"
    echo -e "${BLUE}╚══════════════════════════════════════════════════════════╝${NC}"
    echo ""
    echo -e "${YELLOW}About Claude:${NC}"
    echo "  • Anthropic's most capable AI model"
    echo "  • Excellent for coding, analysis, and writing"
    echo "  • Runs on Google Cloud Vertex AI"
    echo ""
    echo -e "${YELLOW}What you'll need:${NC}"
    echo "  • A GCP account with billing enabled"
    echo "  • A GCP project with Vertex AI API enabled"
    echo "  • Authenticated gcloud CLI"
    echo ""


    if ! check_auth_status; then
        echo -e "${YELLOW}⚠ You're not authenticated with GCP${NC}"
        echo ""
        read -p "Would you like to authenticate now? (y/n): " auth_now
        if [ "$auth_now" = "y" ]; then
            authenticate_gcp || return 1
        else
            echo ""
            echo -e "${YELLOW}Authentication is required to use Claude.${NC}"
            echo "Please select option 4 from the main menu to authenticate."
            echo ""
            read -p "Press Enter to return to main menu..."
            return 1
        fi
    fi
    # Clear any cached project
    gcloud config unset project 2>/dev/null

    
    echo ""
    echo -e "${BLUE}➤ Step 1: Select your GCP project${NC}"
    echo ""
    read -p "Would you like to select from a list of your projects? (y/n): " select_proj
    if [ "$select_proj" = "y" ]; then
        select_gcp_project
        PROJECT_ID=$(gcloud config get-value project 2>/dev/null)
    else
        read -p "Enter your GCP Project ID: " PROJECT_ID
        if [ -z "$PROJECT_ID" ]; then
            echo -e "${RED}Project ID cannot be empty${NC}"
            read -p "Press Enter to try again..."
            return 1
        fi
        gcloud config set project "$PROJECT_ID" 2>/dev/null
        gcloud auth application-default set-quota-project "$PROJECT_ID" 2>/dev/null || true
    fi

    echo ""
    echo -e "${BLUE}➤ Step 2: Choose your region${NC}"
    echo ""
    echo "Available regions for Claude:"
    echo "  • us-east5 (Columbus, USA) - Recommended"
    echo "  • us-central1 (Iowa, USA)"
    echo "  • us-east4 (Virginia, USA)"
    echo "  • europe-west1 (Belgium)"
    echo "  • europe-west4 (Netherlands)"
    echo "  • asia-southeast1 (Singapore)"
    echo ""
    read -p "Enter GCP Region [us-east5]: " REGION
    REGION=${REGION:-us-east5}

    echo ""
    echo -e "${BLUE}➤ Step 3: Select Claude model${NC}"
    echo ""
    echo -e "${BOLD}${WHITE}Claude 4.x Series (Latest Generation):${NC}"
    echo "  1)  claude-sonnet-4-6      - Frontier intelligence at scale ⭐ RECOMMENDED"
    echo "  2)  claude-opus-4-6        - Most intelligent for coding & enterprise"
    echo "  3)  claude-opus-4-5        - Industry leader for coding & agents"
    echo "  4)  claude-haiku-4-5       - Superior intelligence for high-volume tasks"
    echo "  5)  claude-sonnet-4-5      - Powerful for agents & enterprise workflows"
    echo "  6)  claude-opus-4-1        - Sustained performance on long tasks"
    echo "  7)  claude-sonnet-4        - High-volume coding & research"
    echo "  8)  claude-opus-4          - State-of-the-art coding model"
    echo ""
    echo -e "${BOLD}${WHITE}Claude 3.x Series:${NC}"
    echo "  9)  claude-3-7-sonnet      - Extended thinking capabilities"
    echo "  10) claude-3-5-sonnet-v2   - Enhanced agentic & computer use"
    echo "  11) claude-3-5-sonnet      - Powerful & cost-effective"
    echo "  12) claude-3-5-haiku       - Fastest & most cost-effective"
    echo "  13) claude-3-opus          - Top-level performance (Deprecated)"
    echo "  14) claude-3-haiku         - Fastest for simple queries (Deprecated)"
    echo ""
    echo -e "${YELLOW}Note: Models must be enabled in Vertex AI Model Garden first${NC}"
    echo -e "${CYAN}Docs: https://cloud.google.com/vertex-ai/generative-ai/docs/partner-models/use-claude${NC}"
    echo ""
    echo "Enter choice (1-14) or model name:"
    read -p "Choice [1]: " MODEL_CHOICE
    MODEL_CHOICE=${MODEL_CHOICE:-1}
    
    # Map choice to model name
    case $MODEL_CHOICE in
        1|claude-sonnet-4-6)      MODEL="claude-sonnet-4-6" ;;
        2|claude-opus-4-6)        MODEL="claude-opus-4-6" ;;
        3|claude-opus-4-5)        MODEL="claude-opus-4-5" ;;
        4|claude-haiku-4-5)       MODEL="claude-haiku-4-5" ;;
        5|claude-sonnet-4-5)      MODEL="claude-sonnet-4-5" ;;
        6|claude-opus-4-1)        MODEL="claude-opus-4-1" ;;
        7|claude-sonnet-4)        MODEL="claude-sonnet-4" ;;
        8|claude-opus-4)          MODEL="claude-opus-4" ;;
        9|claude-3-7-sonnet)      MODEL="claude-3-7-sonnet" ;;
        10|claude-3-5-sonnet-v2)  MODEL="claude-3-5-sonnet-v2" ;;
        11|claude-3-5-sonnet)     MODEL="claude-3-5-sonnet" ;;
        12|claude-3-5-haiku)      MODEL="claude-3-5-haiku" ;;
        13|claude-3-opus)         MODEL="claude-3-opus" ;;
        14|claude-3-haiku)        MODEL="claude-3-haiku" ;;
        *)
            if [[ $MODEL_CHOICE == claude-* ]]; then
                MODEL="$MODEL_CHOICE"
            else
                echo -e "${RED}Invalid choice. Using default.${NC}"
                MODEL="claude-sonnet-4-6"
            fi
            ;;
    esac

    echo ""
    echo -e "${YELLOW}Saving configuration...${NC}"
    save_config "claude" "PROJECT_ID=$PROJECT_ID
REGION=$REGION
MODEL=$MODEL
ENDPOINT=https://$REGION-aiplatform.googleapis.com"
    
    # Update Claude Code settings if it exists
    CLAUDE_DIR="$HOME/.claude"
    if [ -d "$CLAUDE_DIR" ]; then
        SETTINGS_FILE="$CLAUDE_DIR/settings.json"
        cat > "$SETTINGS_FILE" << EOF
{
  "env": {
    "CLAUDE_CODE_USE_VERTEX": "1",
    "CLOUD_ML_REGION": "$REGION",
    "ANTHROPIC_VERTEX_PROJECT_ID": "$PROJECT_ID"
  }
}
EOF
        echo -e "${GREEN}✓ Updated Claude Code settings${NC}"
    fi

    echo ""
    echo -e "${GREEN}╔══════════════════════════════════════════════════════════╗${NC}"
    echo -e "${GREEN}║                                                          ║${NC}"
    echo -e "${GREEN}║              ✓ CLAUDE CONFIGURED SUCCESSFULLY!           ║${NC}"
    echo -e "${GREEN}║                                                          ║${NC}"
    echo -e "${GREEN}╚══════════════════════════════════════════════════════════╝${NC}"
    echo ""
    echo -e "${BLUE}Configuration Details:${NC}"
    echo -e "  Project:  ${GREEN}$PROJECT_ID${NC}"
    echo -e "  Region:   ${GREEN}$REGION${NC}"
    echo -e "  Model:    ${GREEN}$MODEL${NC}"
    echo ""
    echo -e "${YELLOW}Next steps:${NC}"
    echo "  1. Select option 11 to launch the chat interface"
    echo "  2. Start chatting with Claude!"
    echo ""
    read -p "$(echo -e "${YELLOW}Press Enter to return to main menu...${NC}")"
}

# Function to configure Gemini (Vertex AI)
configure_gemini() {
    # Clear any cached project first
    gcloud config unset project 2>/dev/null || true

    echo -e "${BLUE}\n--- Configuring Gemini via Vertex AI ---${NC}"

    if ! check_gcloud; then
        echo -e "${RED}Please install gcloud CLI first${NC}"
        echo "Visit: https://cloud.google.com/sdk/docs/install"
        return 1
    fi

    if ! check_auth_status; then
        echo ""
        read -p "Authenticate now? (y/n): " auth_now
        if [ "$auth_now" = "y" ]; then
            authenticate_gcp || return 1
        else
            return 1
        fi
    fi
    
    echo ""
    read -p "Select project from list? (y/n): " select_proj
    if [ "$select_proj" = "y" ]; then
        select_gcp_project
        PROJECT_ID=$(gcloud config get-value project 2>/dev/null)
    else
        read -p "Enter GCP Project ID: " PROJECT_ID
        gcloud config set project "$PROJECT_ID"
    fi

    read -p "Enter GCP Region (default: us-central1): " REGION
    REGION=${REGION:-us-central1}

    echo ""
    echo "Available Gemini models:"
    echo "  • gemini-2.5-flash (Gemini 2.5 Flash - Fast & capable) ⭐"
    echo "  • gemini-2.5-pro (Gemini 2.5 Pro - Advanced reasoning)"
    echo "  • gemini-2.5-flash-lite (Gemini 2.5 Flash-Lite - Cost-efficient)"
    echo "  • gemini-2.0-flash (Gemini 2.0 Flash)"
    echo "  • gemini-3.1-pro-preview (Gemini 3.1 Pro - Preview)"
    echo "  • gemini-3-flash-preview (Gemini 3 Flash - Preview)"
    echo ""
    read -p "Enter Gemini Model (default: gemini-2.5-flash): " MODEL
    MODEL=${MODEL:-gemini-2.5-flash}

    save_config "gemini" "PROJECT_ID=$PROJECT_ID
REGION=$REGION
MODEL=$MODEL
ENDPOINT=https://$REGION-aiplatform.googleapis.com"

    echo -e "${GREEN}\n✓ Gemini configured successfully!${NC}"
    echo -e "Project: $PROJECT_ID"
    echo -e "Region: $REGION"
    echo -e "Model: $MODEL"
}

# Function to configure OpenAI
configure_openai() {
    echo -e "${BLUE}\n--- Configuring OpenAI ---${NC}"

    read -sp "Enter your OpenAI API Key: " OPENAI_API_KEY
    echo ""

    read -p "Enter OpenAI Model (default: gpt-4o): " MODEL
    MODEL=${MODEL:-gpt-4o}

    read -p "Enter API Endpoint (default: https://api.openai.com/v1): " ENDPOINT
    ENDPOINT=${ENDPOINT:-https://api.openai.com/v1}

    save_config "openai" "OPENAI_API_KEY=$OPENAI_API_KEY
MODEL=$MODEL
ENDPOINT=$ENDPOINT"

    echo -e "${GREEN}\n✓ OpenAI configured successfully!${NC}"
    echo -e "Model: $MODEL"
}

# Function to test configuration
test_configuration() {
    if ! load_config; then
        echo -e "${RED}No configuration found. Please configure an AI tool first.${NC}"
        return 1
    fi

    echo -e "${BLUE}\n--- Testing $AI_TOOL Configuration ---${NC}"

    case $AI_TOOL in
        claude|gemini)
            echo "Testing Vertex AI connection..."
            gcloud auth application-default print-access-token &> /dev/null
            if [ $? -eq 0 ]; then
                echo -e "${GREEN}✓ Authentication successful${NC}"
            else
                echo -e "${RED}✗ Authentication failed. Run: gcloud auth application-default login${NC}"
                return 1
            fi
            ;;
        openai)
            echo "Testing OpenAI API..."
            curl -s -H "Authorization: Bearer $OPENAI_API_KEY" \
                 -H "Content-Type: application/json" \
                 https://api.openai.com/v1/models &> /dev/null
            if [ $? -eq 0 ]; then
                echo -e "${GREEN}✓ API key is valid${NC}"
            else
                echo -e "${RED}✗ API key validation failed${NC}"
                return 1
            fi
            ;;
    esac
}

# Function to display current configuration
show_config() {
    echo -e "${BLUE}\n--- Current Configuration ---${NC}"
    echo ""
    
    if load_config; then
        echo -e "AI Tool: ${GREEN}$AI_TOOL${NC}"
        case $AI_TOOL in
            claude|gemini)
                echo -e "Project: $PROJECT_ID"
                echo -e "Region: $REGION"
                echo -e "Model: $MODEL"
                echo ""
                echo -e "${BLUE}GCP Authentication:${NC}"
                check_auth_status || true
                ;;
            openai)
                echo -e "Model: $MODEL"
                echo -e "API Key: ${OPENAI_API_KEY:0:10}...${OPENAI_API_KEY: -4}"
                ;;
        esac
    else
        echo -e "${YELLOW}No configuration found${NC}"
    fi
}

# Function to install Claude CLI
install_claude_cli() {
    clear
    echo -e "${MAGENTA}╔══════════════════════════════════════════════════════════╗${NC}"
    echo -e "${MAGENTA}║${NC}                                                          ${MAGENTA}║${NC}"
    echo -e "${MAGENTA}║${NC}              ${BOLD}${CYAN}📦 INSTALL CLAUDE CLI${NC}                     ${MAGENTA}║${NC}"
    echo -e "${MAGENTA}║${NC}                                                          ${MAGENTA}║${NC}"
    echo -e "${MAGENTA}╚══════════════════════════════════════════════════════════╝${NC}"
    echo ""
    
    # Check if already installed
    if command -v claude &> /dev/null; then
        CLAUDE_VERSION=$(claude --version 2>&1 | head -1)
        echo -e "${GREEN}✓ Claude CLI already installed: $CLAUDE_VERSION${NC}"
        echo ""
        echo "Options:"
        echo "  1) Update to latest version"
        echo "  2) Reinstall"
        echo "  3) Uninstall"
        echo "  0) Back to main menu"
        echo ""
        read -p "Choice [0]: " update_choice
        update_choice=${update_choice:-0}
        
        case $update_choice in
            1|2)
                echo ""
                echo -e "${YELLOW}Updating Claude CLI...${NC}"
                npm install -g @anthropic-ai/claude-code@latest
                echo ""
                echo -e "${GREEN}✓ Claude CLI updated!${NC}"
                ;;
            3)
                echo ""
                echo -e "${YELLOW}Uninstalling Claude CLI...${NC}"
                npm uninstall -g @anthropic-ai/claude-code
                echo ""
                echo -e "${GREEN}✓ Claude CLI uninstalled${NC}"
                ;;
        esac
        echo ""
        read -p "Press Enter to continue..."
        return
    fi
    
    echo -e "${BOLD}${CYAN}About Claude CLI:${NC}"
    echo "  • Official Anthropic CLI tool"
    echo "  • Direct access to Claude models"
    echo "  • Requires Node.js and npm"
    echo ""
    
    # Check prerequisites
    echo -e "${BOLD}${YELLOW}Checking prerequisites...${NC}"
    echo ""
    
    if ! command -v node &> /dev/null; then
        echo -e "${RED}✗ Node.js not found${NC}"
        echo ""
        echo "Please install Node.js first:"
        echo "  macOS:   brew install node"
        echo "  Linux:   apt-get install nodejs npm"
        echo "  Windows: https://nodejs.org"
        echo ""
        read -p "Press Enter to continue..."
        return
    fi
    
    if ! command -v npm &> /dev/null; then
        echo -e "${RED}✗ npm not found${NC}"
        echo ""
        read -p "Press Enter to continue..."
        return
    fi
    
    NODE_VERSION=$(node --version)
    NPM_VERSION=$(npm --version)
    echo -e "${GREEN}✓ Node.js: $NODE_VERSION${NC}"
    echo -e "${GREEN}✓ npm: $NPM_VERSION${NC}"
    echo ""
    
    read -p "Install Claude CLI? (y/n) [y]: " confirm
    confirm=${confirm:-y}
    
    if [ "$confirm" = "y" ] || [ "$confirm" = "Y" ]; then
        echo ""
        echo -e "${YELLOW}Installing Claude CLI...${NC}"
        npm install -g @anthropic-ai/claude-code
        echo ""
        if command -v claude &> /dev/null; then
            CLAUDE_VERSION=$(claude --version 2>&1 | head -1)
            echo -e "${GREEN}✓ Claude CLI installed successfully: $CLAUDE_VERSION${NC}"
            echo ""
            echo "Usage: claude [command]"
            echo "Docs:  https://code.claude.com/docs"
        else
            echo -e "${RED}✗ Installation failed${NC}"
        fi
    fi
    
    echo ""
    read -p "Press Enter to continue..."
}

# Function to install Gemini CLI
install_gemini_cli() {
    clear
    echo -e "${MAGENTA}╔══════════════════════════════════════════════════════════╗${NC}"
    echo -e "${MAGENTA}║${NC}                                                          ${MAGENTA}║${NC}"
    echo -e "${MAGENTA}║${NC}              ${BOLD}${CYAN}📦 INSTALL GEMINI CLI${NC}                     ${MAGENTA}║${NC}"
    echo -e "${MAGENTA}║${NC}                                                          ${MAGENTA}║${NC}"
    echo -e "${MAGENTA}╚══════════════════════════════════════════════════════════╝${NC}"
    echo ""
    
    # Check if already installed
    if command -v gemini &> /dev/null; then
        GEMINI_VERSION=$(gemini --version 2>&1 | head -1)
        echo -e "${GREEN}✓ Gemini CLI already installed: $GEMINI_VERSION${NC}"
        echo ""
        echo "Options:"
        echo "  1) Update to latest version"
        echo "  2) Reinstall"
        echo "  3) Uninstall"
        echo "  0) Back to main menu"
        echo ""
        read -p "Choice [0]: " update_choice
        update_choice=${update_choice:-0}
        
        case $update_choice in
            1|2)
                echo ""
                echo -e "${YELLOW}Updating Gemini CLI...${NC}"
                npm install -g @google/gemini-cli@latest
                echo ""
                echo -e "${GREEN}✓ Gemini CLI updated!${NC}"
                ;;
            3)
                echo ""
                echo -e "${YELLOW}Uninstalling Gemini CLI...${NC}"
                npm uninstall -g @google/gemini-cli
                echo ""
                echo -e "${GREEN}✓ Gemini CLI uninstalled${NC}"
                ;;
        esac
        echo ""
        read -p "Press Enter to continue..."
        return
    fi
    
    echo -e "${BOLD}${CYAN}About Gemini CLI:${NC}"
    echo "  • Official Google CLI tool"
    echo "  • Direct access to Gemini models"
    echo "  • Requires Node.js and npm"
    echo ""
    
    # Check prerequisites
    echo -e "${BOLD}${YELLOW}Checking prerequisites...${NC}"
    echo ""
    
    if ! command -v node &> /dev/null; then
        echo -e "${RED}✗ Node.js not found${NC}"
        echo ""
        echo "Please install Node.js first:"
        echo "  macOS:   brew install node"
        echo "  Linux:   apt-get install nodejs npm"
        echo "  Windows: https://nodejs.org"
        echo ""
        read -p "Press Enter to continue..."
        return
    fi
    
    if ! command -v npm &> /dev/null; then
        echo -e "${RED}✗ npm not found${NC}"
        echo ""
        read -p "Press Enter to continue..."
        return
    fi
    
    NODE_VERSION=$(node --version)
    NPM_VERSION=$(npm --version)
    echo -e "${GREEN}✓ Node.js: $NODE_VERSION${NC}"
    echo -e "${GREEN}✓ npm: $NPM_VERSION${NC}"
    echo ""
    
    read -p "Install Gemini CLI? (y/n) [y]: " confirm
    confirm=${confirm:-y}
    
    if [ "$confirm" = "y" ] || [ "$confirm" = "Y" ]; then
        echo ""
        echo -e "${YELLOW}Installing Gemini CLI...${NC}"
        npm install -g @google/gemini-cli
        echo ""
        if command -v gemini &> /dev/null; then
            GEMINI_VERSION=$(gemini --version 2>&1 | head -1)
            echo -e "${GREEN}✓ Gemini CLI installed successfully: $GEMINI_VERSION${NC}"
            echo ""
            echo "Usage: gemini [command]"
            echo "Docs:  https://github.com/google/generative-ai-js"
        else
            echo -e "${RED}✗ Installation failed${NC}"
        fi
    fi
    
    echo ""
    read -p "Press Enter to continue..."
}

# Main menu
while true; do
    clear
    echo -e "${MAGENTA}╔══════════════════════════════════════════════════════════╗${NC}"
    echo -e "${MAGENTA}║${NC}                                                          ${MAGENTA}║${NC}"
    echo -e "${MAGENTA}║${NC}              ${BOLD}${CYAN}🔮 VERTEX CLI - MAIN MENU${NC}                  ${MAGENTA}║${NC}"
    echo -e "${MAGENTA}║${NC}                                                          ${MAGENTA}║${NC}"
    echo -e "${MAGENTA}╚══════════════════════════════════════════════════════════╝${NC}"
    echo ""
    
    # Show current status
    if load_config 2>/dev/null; then
        echo -e "${BOLD}${GREEN}✓ Current AI: ${CYAN}$AI_TOOL${NC}"
        if [ "$AI_TOOL" = "claude" ] || [ "$AI_TOOL" = "gemini" ]; then
            CURRENT_ACCOUNT=$(gcloud auth list --filter=status:ACTIVE --format="value(account)" 2>/dev/null | head -n1)
            if [ -n "$CURRENT_ACCOUNT" ]; then
                echo -e "${BOLD}${GREEN}✓ Authenticated: ${YELLOW}$CURRENT_ACCOUNT${NC}"
            fi
        fi
        echo ""
    fi
    
    echo -e "${BOLD}${CYAN}🤖 AI Configuration:${NC}"
    echo -e "  ${BOLD}${YELLOW}1)${NC} ${WHITE}Configure Claude (Vertex AI)${NC} ${BLUE}- Anthropic's best model${NC}"
    echo -e "  ${BOLD}${YELLOW}2)${NC} ${WHITE}Configure Gemini (Vertex AI)${NC} ${BLUE}- Google's latest AI${NC}"
    echo -e "  ${BOLD}${YELLOW}3)${NC} ${WHITE}Configure OpenAI${NC} ${BLUE}- GPT-4 and more${NC}"
    echo ""
    echo -e "${BOLD}${CYAN}🔐 GCP Management:${NC}"
    echo -e "  ${BOLD}${YELLOW}4)${NC} ${WHITE}Authenticate with GCP${NC} ${BLUE}- Sign in to Google Cloud${NC}"
    echo -e "  ${BOLD}${YELLOW}5)${NC} ${WHITE}Switch Account${NC} ${BLUE}- Change or re-authenticate${NC}"
    echo -e "  ${BOLD}${YELLOW}6)${NC} ${WHITE}Manage Projects & APIs${NC} ${BLUE}- View and configure GCP${NC}"
    echo ""
    echo -e "${BOLD}${CYAN}📦 CLI Tools:${NC}"
    echo -e "  ${BOLD}${YELLOW}7)${NC} ${WHITE}Install/Manage Claude CLI${NC} ${BLUE}- Official Anthropic CLI${NC}"
    echo -e "  ${BOLD}${YELLOW}8)${NC} ${WHITE}Install/Manage Gemini CLI${NC} ${BLUE}- Official Google CLI${NC}"
    echo ""
    echo -e "${BOLD}${CYAN}📊 Status & Testing:${NC}"
    echo -e "  ${BOLD}${YELLOW}9)${NC} ${WHITE}Show Configuration${NC} ${BLUE}- View current settings${NC}"
    echo -e "  ${BOLD}${YELLOW}10)${NC} ${WHITE}Test Configuration${NC} ${BLUE}- Verify everything works${NC}"
    echo ""
    echo -e "${BOLD}${CYAN}💬 Usage:${NC}"
    echo -e "  ${BOLD}${GREEN}11)${NC} ${WHITE}Launch Chat Interface${NC} ${MAGENTA}- Start talking to AI${NC}"
    echo ""
    echo -e "  ${BOLD}${RED}0)${NC} ${WHITE}Exit${NC}"
    echo ""
    echo -e "${CYAN}──────────────────────────────────────────────────────────${NC}"
    echo ""

    read -p "$(echo -e "${BOLD}${CYAN}➤ Select option (0-11): ${NC}")" choice
    echo ""

    case $choice in
        1)
            configure_claude || true
            ;;
        2)
            configure_gemini || true
            ;;
        3)
            configure_openai || true
            ;;
        4)
            authenticate_gcp || true
            ;;
        5)
            switch_gcp_account || true
            ;;
        6)
            manage_gcp_config || true
            ;;
        7)
            install_claude_cli || true
            ;;
        8)
            install_gemini_cli || true
            ;;
        9)
            show_config || true
            ;;
        10)
            test_configuration || true
            ;;
        11)
            if load_config; then
                SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
                clear
                echo -e "${GREEN}✓ Launching AI chat interface...${NC}"
                echo ""
                "$SCRIPT_DIR/vertex-chat"
            else
                echo -e "${RED}✗ No AI configured yet${NC}"
                echo ""
                echo "Please configure an AI tool first:"
                echo "  • Option 1 for Claude"
                echo "  • Option 2 for Gemini"
                echo "  • Option 3 for OpenAI"
                echo ""
                read -p "Press Enter to continue..."
            fi
            ;;
        0)
            clear
            echo -e "${MAGENTA}╔══════════════════════════════════════════════════════════╗${NC}"
            echo -e "${MAGENTA}║${NC}                                                          ${MAGENTA}║${NC}"
            echo -e "${MAGENTA}║${NC}              ${BOLD}${CYAN}Thank you for using Vertex CLI!${NC}             ${MAGENTA}║${NC}"
            echo -e "${MAGENTA}║${NC}                                                          ${MAGENTA}║${NC}"
            echo -e "${MAGENTA}╚══════════════════════════════════════════════════════════╝${NC}"
            echo ""
            echo -e "${BOLD}${YELLOW}⭐ If you found this useful, please star us on GitHub!${NC}"
            echo -e "${CYAN}   https://github.com/code-wiki/vertex-cli${NC}"
            echo ""
            echo -e "${BOLD}${RED}🐛 Found a bug? Have a suggestion?${NC}"
            echo -e "${CYAN}   https://github.com/code-wiki/vertex-cli/issues${NC}"
            echo ""
            exit 0
            ;;
        *)
            echo -e "${BOLD}${RED}✗ Invalid option. Please select 0-11.${NC}"
            echo ""
            read -p "$(echo -e "${YELLOW}Press Enter to continue...${NC}")"
            ;;
    esac
done
