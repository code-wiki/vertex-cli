#!/bin/bash

set -e

CONFIG_FILE="$HOME/.ai-tools-config"

# Colors
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
MAGENTA='\033[0;35m'
CYAN='\033[0;36m'
WHITE='\033[1;37m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

# Spinner function for loading animation
show_spinner() {
    local pid=$1
    local message=$2
    local spinstr='⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏'
    local temp
    
    echo -ne "${DIM}${CYAN}"
    while kill -0 $pid 2>/dev/null; do
        temp=${spinstr#?}
        printf " [%c] %s" "$spinstr" "$message"
        spinstr=$temp${spinstr%"$temp"}
        sleep 0.1
        printf "\r"
    done
    printf "    \r"
    echo -ne "${NC}"
}

# Animated typing effect for a message
typing_effect() {
    local text="$1"
    local color="$2"
    echo -ne "${color}"
    for ((i=0; i<${#text}; i++)); do
        echo -n "${text:$i:1}"
        sleep 0.02
    done
    echo -e "${NC}"
}

# Progress bar animation
show_progress() {
    local duration=$1
    local message=$2
    local width=40
    local progress=0
    
    echo -ne "${DIM}${CYAN}"
    while [ $progress -le $width ]; do
        local filled=$((progress * 100 / width))
        local bar=$(printf "%-${width}s" "█" | tr ' ' '▓' | head -c $progress)
        local empty=$(printf "%-$((width - progress))s" "" | tr ' ' '░')
        printf "\r  %s [%s%s] %d%%" "$message" "$bar" "$empty" "$filled"
        progress=$((progress + 1))
        sleep 0.05
    done
    printf "\r%*s\r" $((width + 20)) ""
    echo -ne "${NC}"
}

# Load configuration
if [ ! -f "$CONFIG_FILE" ]; then
    echo -e "${RED}No configuration found.${NC}"
    echo ""
    echo "Please run vertex-cli first to configure your AI provider:"
    echo -e "  ${BLUE}./vertex-cli${NC}"
    echo ""
    exit 1
fi

source "$CONFIG_FILE"

# Check authentication for Vertex AI
if [ "$AI_TOOL" = "claude" ] || [ "$AI_TOOL" = "gemini" ]; then
    if ! gcloud auth application-default print-access-token &> /dev/null; then
        echo -e "${RED}Not authenticated with GCP${NC}"
        echo ""
        echo "Please authenticate first:"
        echo -e "  ${BLUE}./vertex-cli${NC} (select option 4 to authenticate)"
        echo ""
        echo "Or run directly:"
        echo -e "  ${BLUE}gcloud auth application-default login${NC}"
        echo ""
        exit 1
    fi
    
    # Show current account
    CURRENT_ACCOUNT=$(gcloud auth list --filter=status:ACTIVE --format="value(account)" 2>/dev/null | head -n1)
    if [ -n "$CURRENT_ACCOUNT" ]; then
        clear
        echo ""
        echo -e "${DIM}${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        echo -e "  ${GREEN}✓ Authenticated${NC} as ${YELLOW}$CURRENT_ACCOUNT${NC}"
        echo -e "${DIM}${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        echo ""
    fi
fi

# Function to call Claude via Vertex AI
call_claude() {
    local prompt="$1"
    
    if ! access_token=$(gcloud auth application-default print-access-token 2>&1); then
        echo -e "${RED}Authentication failed. Please run: gcloud auth application-default login${NC}"
        return 1
    fi

    local request_body=$(cat <<EOF
{
  "anthropic_version": "vertex-2023-10-16",
  "messages": [
    {
      "role": "user",
      "content": "$prompt"
    }
  ],
  "max_tokens": 4096
}
EOF
)

    curl -s -X POST \
        -H "Authorization: Bearer $access_token" \
        -H "Content-Type: application/json" \
        "$ENDPOINT/v1/projects/$PROJECT_ID/locations/$REGION/publishers/anthropic/models/$MODEL:rawPredict" \
        -d "$request_body" | jq -r '.content[]?.text // .error.message // "Error: No response"'
}

# Function to call Gemini via Vertex AI
call_gemini() {
    local prompt="$1"
    
    if ! access_token=$(gcloud auth application-default print-access-token 2>&1); then
        echo -e "${RED}Authentication failed. Please run: gcloud auth application-default login${NC}"
        return 1
    fi

    local request_body=$(cat <<EOF
{
  "contents": [
    {
      "role": "user",
      "parts": [
        {
          "text": "$prompt"
        }
      ]
    }
  ],
  "generation_config": {
    "temperature": 0.7,
    "maxOutputTokens": 8192
  }
}
EOF
)

    local response=$(curl -s -X POST \
        -H "Authorization: Bearer $access_token" \
        -H "Content-Type: application/json" \
        "$ENDPOINT/v1/projects/$PROJECT_ID/locations/$REGION/publishers/google/models/$MODEL:generateContent" \
        -d "$request_body")
    
    # Check for error first
    local error_msg=$(echo "$response" | jq -r '.error.message // empty' 2>/dev/null)
    if [ -n "$error_msg" ]; then
        echo -e "${RED}Error: $error_msg${NC}"
        echo -e "${YELLOW}Debug info:${NC}"
        echo "Model: $MODEL"
        echo "Region: $REGION"
        echo "Project: $PROJECT_ID"
        return 1
    fi
    
    # Try to extract the response text
    echo "$response" | jq -r '.candidates[0].content.parts[0].text // "Error: No valid response"'
}

# Function to call OpenAI
call_openai() {
    local prompt="$1"

    local request_body=$(cat <<EOF
{
  "model": "$MODEL",
  "messages": [
    {
      "role": "user",
      "content": "$prompt"
    }
  ],
  "max_tokens": 4096
}
EOF
)

    curl -s -X POST \
        -H "Authorization: Bearer $OPENAI_API_KEY" \
        -H "Content-Type: application/json" \
        "$ENDPOINT/chat/completions" \
        -d "$request_body" | jq -r '.choices[0].message.content // .error.message // "Error: No response"'
}

# Main chat loop
clear
echo -e "${MAGENTA}╔════════════════════════════════════════════════════════╗${NC}"
echo -e "${MAGENTA}║${NC}    ${BOLD}${CYAN}✨ AI Chat Interface - $AI_TOOL ✨${NC}            ${MAGENTA}║${NC}"
echo -e "${MAGENTA}╚════════════════════════════════════════════════════════╝${NC}"
echo ""
echo -e "${BOLD}${GREEN}✓ Chat session started!${NC}"
echo -e "${DIM}${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${CYAN}Model:${NC}    ${YELLOW}$MODEL${NC}"
echo -e "${CYAN}Commands:${NC} ${WHITE}'exit'${NC} ${DIM}or${NC} ${WHITE}'quit'${NC} ${DIM}to end${NC} │ ${WHITE}'clear'${NC} ${DIM}to clear screen${NC}"
echo -e "${DIM}${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo ""

while true; do
    echo -ne "${BOLD}${BLUE}┌─[${NC}${CYAN}You${NC}${BOLD}${BLUE}]${NC}\n${BOLD}${BLUE}└─▶${NC} "
    read -r user_input

    if [ -z "$user_input" ]; then
        continue
    fi

    if [ "$user_input" = "exit" ] || [ "$user_input" = "quit" ]; then
        echo ""
        echo -e "${DIM}${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        typing_effect "✨ Thank you for using Vertex CLI! Goodbye! 👋" "${BOLD}${GREEN}"
        echo -e "${DIM}${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        echo ""
        exit 0
    fi
    
    if [ "$user_input" = "clear" ]; then
        clear
        echo -e "${MAGENTA}╔════════════════════════════════════════════════════════╗${NC}"
        echo -e "${MAGENTA}║${NC}    ${BOLD}${CYAN}✨ AI Chat Interface - $AI_TOOL ✨${NC}            ${MAGENTA}║${NC}"
        echo -e "${MAGENTA}╚════════════════════════════════════════════════════════╝${NC}"
        echo ""
        echo -e "${DIM}${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        echo ""
        continue
    fi

    echo ""
    echo -e "${DIM}${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    
    # Show thinking animation
    echo -ne "${DIM}${CYAN}⚡ AI is thinking"
    for i in {1..3}; do
        echo -n "."
        sleep 0.3
    done
    echo -e "${NC}"
    
    echo -e "${BOLD}${GREEN}┌─[${NC}${YELLOW}$AI_TOOL AI${NC}${BOLD}${GREEN}]${NC}"
    echo -e "${BOLD}${GREEN}└─▶${NC} "
    
    # Create a temporary file for the response
    TEMP_RESPONSE=$(mktemp)
    
    # Call API in background and show spinner
    case $AI_TOOL in
        claude)
            (call_claude "$user_input" > "$TEMP_RESPONSE") &
            ;;
        gemini)
            (call_gemini "$user_input" > "$TEMP_RESPONSE") &
            ;;
        openai)
            (call_openai "$user_input" > "$TEMP_RESPONSE") &
            ;;
        *)
            echo -e "${RED}Unknown AI tool: $AI_TOOL${NC}"
            rm -f "$TEMP_RESPONSE"
            exit 1
            ;;
    esac
    
    # Get the PID of the background process
    API_PID=$!
    
    # Show spinner while waiting
    show_spinner $API_PID "Processing your request"
    
    # Wait for the API call to complete
    wait $API_PID
    
    # Display the response with nice formatting
    if [ -f "$TEMP_RESPONSE" ] && [ -s "$TEMP_RESPONSE" ]; then
        # Check if response contains an error
        if grep -q "Error:" "$TEMP_RESPONSE"; then
            echo -e "${RED}$(cat "$TEMP_RESPONSE")${NC}"
        else
            # Display response with syntax highlighting for code blocks
            cat "$TEMP_RESPONSE" | while IFS= read -r line; do
                # Detect code blocks
                if [[ "$line" =~ ^\`\`\` ]]; then
                    echo -e "${DIM}${CYAN}$line${NC}"
                elif [[ "$line" =~ ^# ]]; then
                    # Headings
                    echo -e "${BOLD}${WHITE}$line${NC}"
                elif [[ "$line" =~ ^\* ]] || [[ "$line" =~ ^- ]]; then
                    # Bullet points
                    echo -e "${CYAN}$line${NC}"
                else
                    # Regular text
                    echo -e "${WHITE}$line${NC}"
                fi
            done
        fi
    else
        echo -e "${RED}Error: No response received${NC}"
    fi
    
    # Cleanup
    rm -f "$TEMP_RESPONSE"
    
    echo ""
    echo -e "${DIM}${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
done
